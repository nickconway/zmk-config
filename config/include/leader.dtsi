/*                KEY POSITIONS

  ╭─────────────────────╮ ╭─────────────────────╮
  │ LT0 LT1 LT2 LT3 LT4 │ │ RT0 RT1 RT2 RT3 RT4 │
  │ LM0 LM1 LM2 LM3 LM4 │ │ RM0 RM1 RM2 RM3 RM4 │
  │ LB0 LB1 LB2 LB3 LB4 │ │ RB0 RB1 RB2 RB3 RB4 │
  ╰───────╮ LH0 LH1 LH2 │ │ RH0 RH1 RH2 ╭───────╯
          ╰─────────────╯ ╰─────────────╯ */

#define LEADER(leader_name, name, leader_sequence, leader_bindings) \
    / { \
        behaviors { \
            leader_name: leader_name { \
                compatible = "zmk,behavior-leader-key"; \
                #binding-cells = <0>; \
                leader_sequence_##name { \
                    key-positions = <leader_sequence>; \
                    bindings = <leader_bindings>; \
                }; \
            }; \
        }; \
    };

LEADER(leader, close, LT0, &kp LA(F4))
LEADER(leader, bootloader, LT2, &bootloader)
LEADER(leader, browser, LT4, &kp LG(N1))
LEADER(leader, reset, LM1, &sys_reset)
LEADER(leader, spotify, LM2, &kp LG(N3))
LEADER(leader, terminal, LM3, &kp LG(GRAVE))
LEADER(leader, lastdevice, RT1, &last_dev)

LEADER(leader, mac, RM0, &tog MAC)
LEADER(leader, output, RM4, &out OUT_TOG)
LEADER(leader, discord, LB3, &kp LG(N2))
LEADER(leader, delete, LH2, &kp DEL)

LEADER(leader, btclear, LH2 RT4, &bt BT_CLR)
LEADER(leader, bt0, LH2 LB0, &bt BT_SEL 0)
LEADER(leader, bt1, LH2 LB1, &bt BT_SEL 1)
LEADER(leader, bt2, LH2 LB2, &bt BT_SEL 2)
LEADER(leader, bt3, LH2 LB3, &bt BT_SEL 3)
LEADER(leader, bt4, LH2 LB4, &bt BT_SEL 4)

LEADER(leader, zoom, LH2 LH2 LB0, &kp F9)
LEADER(leader, preview, LH2 LH2 RM1, &kp LS(F9))

LEADER(leader2, reset_split, RM3, &sys_reset)
